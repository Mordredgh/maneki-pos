{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "typeRoots": ["./types"],
    "baseUrl": ".",
    "paths": {
      "*": ["./js/*"]
    }
  },
  "include": ["js/**/*.js"],
  "exclude": ["node_modules", "dist", "split_files.js"]
}
