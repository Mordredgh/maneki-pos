{
  "compilerOptions": {
    "target": "ES2020",
    "module": "preserve",
    "moduleResolution": "bundler",
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "typeRoots": ["./types"]
  },
  "include": ["js/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "split_files.js"]
}
